    { "properties": { "code": { "const": "H5" }, "name": { "const": "反常识与悬念" }, "bucket": { "const": "H" } } },
    { "properties": { "code": { "const": "H6" }, "name": { "const": "场景/人群代入" }, "bucket": { "const": "H" } } },
    { "properties": { "code": { "const": "H7" }, "name": { "const": "明星/权威同款" }, "bucket": { "const": "H" } } },

    { "properties": { "code": { "const": "E0" }, "name": { "const": "单点演示" }, "bucket": { "const": "E" } } },
    { "properties": { "code": { "const": "E1" }, "name": { "const": "效果测评" }, "bucket": { "const": "E" } } },
    { "properties": { "code": { "const": "E2" }, "name": { "const": "暴力实测" }, "bucket": { "const": "E" } } },
    { "properties": { "code": { "const": "E3" }, "name": { "const": "对比/拉踩" }, "bucket": { "const": "E" } } },
    { "properties": { "code": { "const": "E4" }, "name": { "const": "感官实证" }, "bucket": { "const": "E" } } },
    { "properties": { "code": { "const": "E5" }, "name": { "const": "保姆级教程" }, "bucket": { "const": "E" } } },
    { "properties": { "code": { "const": "E6" }, "name": { "const": "成分/参数科普" }, "bucket": { "const": "E" } } },
