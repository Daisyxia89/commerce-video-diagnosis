    "bucket": {
      "type": "string",
      "enum": ["H", "E", "C"]
    },
    "definition": {
      "type": "string",
      "minLength": 1
    },
    "appeal": {
      "type": "string",
      "minLength": 1
    },
    "notes": {
      "type": "string",
      "minLength": 1
    }
