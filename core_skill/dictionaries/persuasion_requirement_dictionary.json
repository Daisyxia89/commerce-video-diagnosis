    {"requirement_id": "expose_current_pain", "requirement_name": "暴露当前痛点", "decision_gap": "need_gap", "definition": "内容需要让用户感知到当前已经存在、可被察觉的问题或损失，建立需求成立的前提。", "default_priority": "high", "default_required": true, "default_sequence_rank": 10, "status": "active", "version": "v3.1_active_mvp_23"},
    {"requirement_id": "clarify_usage_scenario", "requirement_name": "明确使用场景", "decision_gap": "need_gap", "definition": "内容需要说明商品在什么具体场景下被使用，让用户判断与自己是否相关。", "default_priority": "medium", "default_required": false, "default_sequence_rank": 11, "status": "active", "version": "v3.1_active_mvp_23"},
    {"requirement_id": "identify_target_user", "requirement_name": "锁定目标人群", "decision_gap": "need_gap", "definition": "内容需要明确商品适合的人群，让用户对号入座。", "default_priority": "medium", "default_required": false, "default_sequence_rank": 12, "status": "active", "version": "v3.1_active_mvp_23"},
    {"requirement_id": "amplify_unmet_need", "requirement_name": "放大未满足需求", "decision_gap": "need_gap", "definition": "内容需要放大用户尚未被满足的需求强度。", "default_priority": "medium", "default_required": false, "default_sequence_rank": 13, "status": "candidate", "version": "v3.1_candidate_pool_36"},
